{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "additionalProperties": {
        "$ref": "#/$defs/graph_step"
    },
    "minProperties": 1,
    "$defs": {
        "graph_step": {
            "oneOf": [
                {
                    "$ref": "#/$defs/swap"
                },
                {
                    "$ref": "#/$defs/positional_invocation"
                },
                {
                    "$ref": "#/$defs/keyword_invocation"
                },
                {
                    "$ref": "#/$defs/mixed_invocation"
                }
            ]
        },
        "swap": {
            "title": "Swap choices as a list",
            "type": "object",
            "properties": {
                "dependencies": {
                    "$ref": "#/$defs/step_dependencies"
                }
            },
            "patternProperties": {
                "^\\?.*": { "$ref": "#/$defs/swap_choice" }               
            },
            "additionalProperties": false
        },
        "swap_choice": {
            "oneOf": [
                {
                    "$ref": "#/$defs/swap_positional_invocation"
                },
                {
                    "$ref": "#/$defs/swap_keyword_invocation"
                },
                {
                    "$ref": "#/$defs/swap_mixed_invocation"
                }
            ]
        },
        "positional_invocation": {
            "title": "Positional invocation",
            "type": "object",
            "not": {
                "$comment": "If the 'task' property is present, we always treat as a mixed invocation.",
                "required": [
                    "task"
                ]
            },
            "properties": {
                "dependencies": {
                    "$ref": "#/$defs/step_dependencies"
                }
            },
            "additionalProperties": {
                "$comment": "The task plugin short name + arg value(s)",
                "type": [
                    "string",
                    "number",
                    "boolean",
                    "null",
                    "array"
                ]
            },
            "minProperties": 1,
            "maxProperties": 2
        },
        "keyword_invocation": {
            "title": "Keyword invocation",
            "type": "object",
            "not": {
                "$comment": "If the 'task' property is present, we always treat as a mixed invocation.",
                "required": [
                    "task"
                ]
            },
            "properties": {
                "dependencies": {
                    "$ref": "#/$defs/step_dependencies"
                }
            },
            "patternProperties": {
                "^(?!\\?|dependencies$).*": { "type": "object"}
            },
            "minProperties": 1,
            "maxProperties": 2
        },
        "mixed_invocation": {
            "title": "Mixed position/keyword invocation",
            "type": "object",
            "properties": {
                "task": {
                    "$comment": "Task plugin short name",
                    "type": "string",
                    "minLength": 1
                },
                "args": {
                    "$comment": "Positional args",
                    "type": [
                        "string",
                        "number",
                        "boolean",
                        "null",
                        "array"
                    ]
                },
                "kwargs": {
                    "$comment": "Keyword args",
                    "type": "object"
                },
                "dependencies": {
                    "$ref": "#/$defs/step_dependencies"
                }
            },
            "required": [
                "task"
            ],
            "additionalProperties": false
        },        
        "swap_positional_invocation": {
            "title": "Positional invocation",
            "type": "object",
            "not": {
                "$comment": "If the 'task' property is present, we always treat as a mixed invocation.",
                "required": [
                    "task"
                ]
            },
            "additionalProperties": {
                "$comment": "The task plugin short name + arg value(s)",
                "type": [
                    "string",
                    "number",
                    "boolean",
                    "null",
                    "array"
                ]
            },
            "minProperties": 1,
            "maxProperties": 1
        },
        "swap_keyword_invocation": {
            "title": "Keyword invocation",
            "type": "object",
            "not": {
                "$comment": "If the 'task' property is present, we always treat as a mixed invocation.",
                "required": [
                    "task"
                ]
            },
            "additionalProperties": {
                "$comment": "The task plugin short name + kwargs",
                "type": "object"
            },
            "minProperties": 1,
            "maxProperties": 1
        },
        "swap_mixed_invocation": {
            "title": "Mixed position/keyword invocation",
            "type": "object",
            "properties": {
                "task": {
                    "$comment": "Task plugin short name",
                    "type": "string",
                    "minLength": 1
                },
                "args": {
                    "$comment": "Positional args",
                    "type": [
                        "string",
                        "number",
                        "boolean",
                        "null",
                        "array"
                    ]
                },
                "kwargs": {
                    "$comment": "Keyword args",
                    "type": "object"
                }
            },
            "required": [
                "task"
            ],
            "additionalProperties": false
        },
        "step_dependencies": {
            "oneOf": [
                {
                    "title": "Dependencies as a list",
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                {
                    "title": "Single dependency as a string",
                    "type": "string"
                }
            ]
        }

    }
}